# ---------------------------------------------------------------------------
# Runtime data — NEVER commit. Created by the container at first start.
# ---------------------------------------------------------------------------

# Application state: live MongoDB, config, logs, snapshots, backups, metadata.
# Also contains the controller's TLS material (keystore/truststore = private keys).
/data/

# Recorded footage (can be hundreds of GB). Bind-mounted, regenerated by the app.
/videos/

# ---------------------------------------------------------------------------
# Secrets — defensive patterns in case data/ is ever relocated.
# ---------------------------------------------------------------------------
*keystore
*truststore
*.jks
*.p12
*.pem
*.key
.env
.env.*
!.env.example

# Backup archives of data/ (and videos/) — these contain the same TLS keystores,
# truststore, and live database as data/, so they must never be committed.
*.tgz
*.tar.gz
*.tar

# ---------------------------------------------------------------------------
# Local tooling / editor / OS noise
# ---------------------------------------------------------------------------
.claude/
*.log
.DS_Store
